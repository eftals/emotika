{
  "name": "emotika",
  "version": "1.0.0",
  "description": "Multi-tiered application with Python, React, Redis, and ASP.NET REST services",
  "scripts": {
    "build": "npm run build:frontend && npm run build:python && npm run build:dotnet",
    "build:frontend": "cd src/frontend && npm install && npm run build",
    "build:python": "cd src/python && pip install -r requirements.txt",
    "build:dotnet": "cd src/dotnet && dotnet build",
    "start": "docker-compose up",
    "start:build": "docker-compose up --build",
    "stop": "docker-compose down",
    "stop:volumes": "docker-compose down -v",
    "logs": "docker-compose logs",
    "logs:frontend": "docker-compose logs frontend",
    "logs:python": "docker-compose logs python-backend",
    "logs:dotnet": "docker-compose logs dotnet-backend",
    "logs:redis": "docker-compose logs redis",
    "restart:frontend": "docker-compose restart frontend",
    "restart:python": "docker-compose restart python-backend",
    "restart:dotnet": "docker-compose restart dotnet-backend",
    "restart:redis": "docker-compose restart redis",
    "dev": "npm run build && npm run start:build",
    "setup": "npm install && npm run build",
    "start:os": "node scripts/start-os.js",
    "stop:os": "node scripts/stop-os.js"
  },
  "keywords": [
    "multi-tiered",
    "python",
    "react",
    "redis",
    "asp.net",
    "docker"
  ],
  "author": "",
  "license": "MIT"
} 